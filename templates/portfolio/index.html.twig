{% extends 'base.html.twig' %}

{% block title %}Accueil - Aymen Boumliki{% endblock %}

{% block body %}
<section class="page-home">
    <div class="container" style="display: flex; justify-content: center; align-items: center; min-height: 80vh; padding: 20px;">
        
        <div class="glass-card" style="max-width: 800px; width: 100%; text-align: center; border-top: 6px solid var(--primary);">
            
            {# 1. Photo de profil (Lien direct vers public/aymen.png) #}
            <div style="position: relative; display: inline-block; margin-bottom: 25px;">
                <img src="{{ asset('aymen.png') }}" alt="Aymen Boumliki" 
                     style="width: 170px; height: 170px; border-radius: 50%; object-fit: cover; border: 5px solid white; box-shadow: 0 10px 25px rgba(0,0,0,0.1); background: white;">
                
                {# Badge bleu "Vérifié" #}
                <div style="position: absolute; top: 15px; right: 5px; background: var(--primary); color: white; width: 38px; height: 38px; border-radius: 50%; display: flex; align-items: center; justify-content: center; border: 4px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.1);">
                    <i class="fas fa-check" style="font-size: 0.85rem;"></i>
                </div>
            </div>

            {# 2. Titre et Sous-titre #}
            <h1 style="font-size: 3rem; font-weight: 800; color: var(--dark); margin-bottom: 10px; letter-spacing: -1px;">
                Bonjour, je suis <span style="color: var(--primary);">Aymen</span>
            </h1>
            
            <p style="font-size: 1.5rem; color: #64748b; font-weight: 600; margin-bottom: 30px;">
                Étudiant en BUT Réseaux et Télécommunications
            </p>

            {# 3. Bloc Citation #}
            <div style="background: rgba(14, 165, 233, 0.05); padding: 30px; border-radius: 20px; border-left: 5px solid var(--primary); margin: 30px 0;">
                <p style="font-style: italic; color: #475569; font-size: 1.25rem; margin: 0; line-height: 1.8;">
                    <i class="fas fa-quote-left" style="color: var(--primary); margin-right: 12px; opacity: 0.4;"></i>
                    Passionné par l'informatique et compétiteur dans l'âme, je mets ma détermination 
                    et mon esprit d'équipe au service de mes projets technologiques.
                    <i class="fas fa-quote-right" style="color: var(--primary); margin-left: 12px; opacity: 0.4;"></i>
                </p>
            </div>

            {# 4. Bouton Explorer #}
            <div style="margin-top: 40px;">
                <a href="{{ path('app_projects') }}" class="btn-main" style="padding: 18px 45px; font-size: 1.15rem; text-decoration: none;">
                    Explorer mon univers <i class="fas fa-arrow-right" style="margin-left: 10px;"></i>
                </a>
            </div>

            {# 5. Badges de compétences #}
            <div style="margin-top: 50px; display: flex; justify-content: center; gap: 30px; opacity: 0.7; font-size: 1rem; font-weight: 600; color: var(--dark);">
                <span><i class="fas fa-network-wired" style="color: var(--primary); margin-right: 8px;"></i> Réseaux</span>
                <span><i class="fas fa-code" style="color: var(--primary); margin-right: 8px;"></i> Développement</span>
                <span><i class="fas fa-shield-alt" style="color: var(--primary); margin-right: 8px;"></i> Télécoms</span>
            </div>

        </div>
    </div>
</section>
{% endblock %}