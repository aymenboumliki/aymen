{% extends 'base.html.twig' %}

{% block title %}Accueil — Aymen Boumliki{% endblock %}

{% block body %}

<style>
    /* ── Hero wrapper ── */
    .hero {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 72vh;
        padding: 40px 0;
    }

    .hero-card {
        max-width: 780px;
        width: 100%;
        background: var(--bg-card);
        border: 1px solid var(--border);
        padding: 48px 44px;
        text-align: center;
        position: relative;
        overflow: hidden;
        transition: border-color 0.3s, box-shadow 0.3s;
    }

    /* Coin décoratif top-left */
    .hero-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 80px; height: 80px;
        border-top: 2px solid var(--accent);
        border-left: 2px solid var(--accent);
        opacity: 0.5;
    }

    /* Coin décoratif bottom-right */
    .hero-card::after {
        content: '';
        position: absolute;
        bottom: 0; right: 0;
        width: 80px; height: 80px;
        border-bottom: 2px solid var(--accent-2);
        border-right: 2px solid var(--accent-2);
        opacity: 0.5;
    }

    .hero-card:hover {
        border-color: var(--border-hover);
        box-shadow: 0 0 40px var(--accent-glow);
    }

    /* ── Photo ── */
    .avatar-wrap {
        position: relative;
        display: inline-block;
        margin-bottom: 32px;
    }

    .avatar-wrap img {
        width: 220px;
        height: 220px;
        object-fit: cover;
        object-position: center 15%;
        border: 1px solid var(--accent);
        box-shadow: 0 0 20px var(--accent-glow);
        filter: none;
        display: block;
    }

    .avatar-badge {
        position: absolute;
        bottom: -10px;
        right: -12px;
        background: var(--bg);
        border: 1px solid var(--accent);
        color: var(--accent);
        font-size: 0.65rem;
        padding: 4px 10px;
        letter-spacing: 0.1em;
        display: flex;
        align-items: center;
        gap: 5px;
    }

    .dot-live {
        width: 6px;
        height: 6px;
        background: var(--accent);
        border-radius: 50%;
        animation: pulse-live 1.4s ease-in-out infinite;
        box-shadow: 0 0 6px var(--accent);
    }

    @keyframes pulse-live {
        0%, 100% { opacity: 1; transform: scale(1); }
        50%       { opacity: 0.3; transform: scale(0.7); }
    }

    /* ── Identité ── */
    .hero-title {
        font-family: 'Syne', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        color: var(--text-bright);
        margin-bottom: 10px;
        line-height: 1.2;
    }

    .hero-title .prompt { color: var(--accent-2); }
    .hero-title .name   { color: var(--accent); }

    .hero-sub {
        font-size: 0.82rem;
        color: var(--text-dim);
        letter-spacing: 0.08em;
        margin-bottom: 32px;
    }

    /* ── Bio terminal ── */
    .bio-block {
        background: rgba(0, 229, 255, 0.03);
        border: 1px dashed rgba(0, 229, 255, 0.2);
        padding: 20px 24px;
        margin: 28px 0 36px;
        text-align: left;
        font-size: 0.85rem;
        line-height: 1.75;
        position: relative;
    }

    .bio-block .cmd {
        color: var(--accent-2);
        display: block;
        margin-bottom: 8px;
        font-size: 0.78rem;
    }

    .bio-block p {
        color: var(--text);
        margin: 0;
    }

    /* ── Bouton hero ── */
    .hero-cta {
        display: inline-block;
        padding: 12px 28px;
        font-family: 'Space Mono', monospace;
        font-size: 0.82rem;
        text-decoration: none;
        color: var(--bg);
        background: var(--accent);
        border: 1px solid var(--accent);
        letter-spacing: 0.06em;
        transition: background 0.2s, box-shadow 0.2s, transform 0.2s;
        box-shadow: 0 0 20px var(--accent-glow);
    }

    .hero-cta:hover {
        background: transparent;
        color: var(--accent);
        transform: translateY(-2px);
        box-shadow: 0 0 32px var(--accent-glow);
    }

    /* ── Badges ── */
    .badges {
        display: flex;
        justify-content: center;
        flex-wrap: wrap;
        gap: 12px;
        margin-top: 44px;
    }

    .badge-item {
        display: flex;
        align-items: center;
        gap: 7px;
        font-size: 0.72rem;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--text-dim);
        border: 1px solid var(--border);
        padding: 6px 14px;
        transition: color 0.2s, border-color 0.2s;
    }

    .badge-item:hover {
        color: var(--accent);
        border-color: var(--border-hover);
    }

    .badge-item i { color: var(--accent-2); font-size: 0.8rem; }
</style>

<section class="hero">
    <div class="hero-card">

        {# ── Photo ── #}
        <div class="avatar-wrap">
            <img src="{{ asset('photo_aymen.png') }}" alt="Aymen Boumliki">
            <div class="avatar-badge">
                <span class="dot-live"></span>
                ONLINE
            </div>
        </div>

        {# ── Identité ── #}
        <h1 class="hero-title">
            <span class="prompt">▸ whoami</span><br>
            <span class="name">Aymen Boumliki</span>
        </h1>

        <p class="hero-sub">[ Étudiant BUT Réseaux & Télécommunications — Roanne ]</p>

        {# ── Bio terminal ── #}
        <div class="bio-block">
            <span class="cmd">$ cat mission.txt</span>
            <p>
                Passionné par les réseaux et la cybersécurité, je mets ma détermination
                et mon esprit d'équipe au service de projets technologiques concrets.
            </p>
        </div>

        {# ── CTA ── #}
        <a href="{{ path('app_projects') }}" class="hero-cta">
            ./view_projects.sh <i class="fas fa-terminal" style="margin-left: 8px;"></i>
        </a>

        {# ── Badges ── #}
        <div class="badges">
            <div class="badge-item"><i class="fas fa-network-wired"></i> Network Admin</div>
            <div class="badge-item"><i class="fas fa-code"></i> Symfony Dev</div>
            <div class="badge-item"><i class="fas fa-shield-halved"></i> Cyber Sec</div>
        </div>

    </div>
</section>

{% endblock %}
