{% extends 'base.html.twig' %}

{% block title %}Mon CV — Aymen Boumliki{% endblock %}

{% block body %}

<style>
    .cv-grid {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 24px;
        align-items: start;
        padding-top: 48px;
    }

    .cv-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        padding: 32px;
        margin-bottom: 24px;
        transition: border-color 0.3s, box-shadow 0.3s;
        position: relative;
        overflow: hidden;
    }

    .cv-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
    }

    .cv-card:hover {
        border-color: var(--border-hover);
        box-shadow: 0 0 24px var(--accent-glow);
    }

    .cv-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 28px;
    }

    .cv-card-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 1.8rem;
        font-weight: 800;
        color: var(--text-bright);
        margin: 0;
    }

    .status-badge {
        font-size: 0.65rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #22c55e;
        border: 1px solid #22c55e;
        padding: 4px 12px;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .status-badge::before {
        content: '';
        width: 6px; height: 6px;
        background: #22c55e;
        border-radius: 50%;
        animation: pulse-live 1.4s ease-in-out infinite;
        box-shadow: 0 0 6px #22c55e;
    }

    @keyframes pulse-live {
        0%, 100% { opacity: 1; }
        50%       { opacity: 0.2; }
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        background: rgba(0, 229, 255, 0.03);
        border: 1px solid var(--border);
        padding: 18px 20px;
        margin-bottom: 32px;
    }

    .info-item small {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--accent);
        display: block;
        margin-bottom: 6px;
    }

    .info-item p {
        margin: 0;
        font-size: 0.82rem;
        color: var(--text);
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .info-item p i { color: var(--accent-2); }

    .cv-section-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-family: 'Syne', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-bright);
        margin-bottom: 24px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .cv-section-title i { color: var(--accent); font-size: 0.9rem; }

    .timeline {
        border-left: 1px solid var(--border);
        padding-left: 24px;
        margin-left: 6px;
    }

    .timeline-item {
        position: relative;
        margin-bottom: 28px;
    }

    .timeline-item::before {
        content: '';
        position: absolute;
        left: -30px;
        top: 6px;
        width: 10px; height: 10px;
        background: var(--accent);
        border: 2px solid var(--bg-card);
        box-shadow: 0 0 8px var(--accent-glow);
    }

    .timeline-item h4 {
        font-family: 'Syne', sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--text-bright);
        margin: 0 0 6px;
    }

    .timeline-item .period {
        font-size: 0.75rem;
        color: var(--accent);
        margin: 0 0 6px;
        letter-spacing: 0.04em;
    }

    .timeline-item p {
        font-size: 0.82rem;
        color: var(--text-dim);
        margin: 0;
        line-height: 1.6;
    }

    .timeline-item ul {
        margin: 6px 0 0;
        padding-left: 16px;
        font-size: 0.82rem;
        color: var(--text-dim);
        line-height: 1.7;
    }

    .skills-list {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .skill-row {
        display: flex;
        align-items: center;
        gap: 16px;
        padding: 14px 16px;
        border: 1px solid var(--border);
        background: rgba(0,229,255,0.02);
        transition: border-color 0.2s, transform 0.2s, box-shadow 0.2s;
        cursor: default;
    }

    .skill-row:hover {
        transform: translateX(6px);
        border-color: var(--border-hover);
        box-shadow: 0 0 14px var(--accent-glow);
    }

    .skill-icon {
        width: 42px; height: 42px;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent);
        font-size: 1.2rem;
        flex-shrink: 0;
        background: rgba(0,229,255,0.05);
    }

    .skill-details strong {
        display: block;
        font-size: 0.88rem;
        color: var(--text-bright);
        margin-bottom: 3px;
    }

    .skill-details p {
        margin: 0;
        font-size: 0.75rem;
        color: var(--text-dim);
    }

    .skill-details p i { color: var(--accent-2); margin-right: 4px; }

    .skills-footer {
        margin-top: 24px;
        padding-top: 18px;
        border-top: 1px solid var(--border);
        text-align: center;
    }

    .skill-link {
        font-size: 0.78rem;
        color: var(--accent);
        text-decoration: none;
        letter-spacing: 0.04em;
        transition: text-shadow 0.2s;
    }

    .skill-link:hover { text-shadow: 0 0 8px var(--accent-glow); }

    .skills-footer p {
        font-size: 0.72rem;
        color: var(--text-dim);
        margin-top: 10px;
        line-height: 1.5;
    }

    .tag-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 8px;
    }

    .tag {
        font-size: 0.7rem;
        padding: 3px 10px;
        border: 1px solid var(--border);
        color: var(--accent);
        letter-spacing: 0.06em;
        background: rgba(0,229,255,0.04);
    }

    .cert-item {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 12px 0;
        border-bottom: 1px solid var(--border);
    }

    .cert-item:last-child { border-bottom: none; }

    .cert-item i { color: var(--accent); margin-top: 2px; flex-shrink: 0; }

    .cert-item div strong {
        display: block;
        font-size: 0.85rem;
        color: var(--text-bright);
        margin-bottom: 3px;
    }

    .cert-item div p {
        margin: 0;
        font-size: 0.75rem;
        color: var(--text-dim);
        line-height: 1.5;
    }

    .cv-sidebar {
        position: sticky;
        top: 80px;
    }

    .sidebar-card {
        background: var(--bg-surface);
        border: 1px solid var(--border);
        padding: 32px 28px;
        position: relative;
        overflow: hidden;
    }

    .sidebar-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--accent-2), var(--accent));
    }

    .sidebar-card .pdf-icon {
        text-align: center;
        margin-bottom: 24px;
    }

    .sidebar-card .pdf-icon i {
        font-size: 3rem;
        color: var(--accent);
        display: block;
        margin-bottom: 12px;
        filter: drop-shadow(0 0 10px var(--accent-glow));
    }

    .sidebar-card .pdf-icon h2 {
        font-family: 'Syne', sans-serif;
        font-size: 1.1rem;
        color: var(--text-bright);
        margin: 0 0 6px;
    }

    .sidebar-card .pdf-icon p {
        font-size: 0.78rem;
        color: var(--text-dim);
        margin: 0;
    }

    .contact-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-bottom: 24px;
    }

    .contact-list a {
        font-size: 0.78rem;
        color: var(--text);
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: color 0.2s;
    }

    .contact-list a:hover { color: var(--accent); }

    .contact-list a i { color: var(--accent); width: 14px; }

    .cv-form {
        display: flex;
        flex-direction: column;
        gap: 12px;
        margin-top: 20px;
    }

    .cv-form input {
        padding: 11px 14px;
        background: var(--bg-card);
        border: 1px solid var(--border);
        color: var(--text);
        font-family: 'Space Mono', monospace;
        font-size: 0.78rem;
        outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
    }

    .cv-form input::placeholder { color: var(--text-dim); }

    .cv-form input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 10px var(--accent-glow);
    }

    .cv-form button {
        padding: 12px;
        background: var(--accent);
        color: var(--bg);
        border: none;
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        letter-spacing: 0.06em;
        cursor: pointer;
        transition: background 0.2s, box-shadow 0.2s;
        font-weight: 700;
    }

    .cv-form button:hover {
        background: transparent;
        color: var(--accent);
        box-shadow: inset 0 0 0 1px var(--accent), 0 0 16px var(--accent-glow);
    }

    @media (max-width: 900px) {
        .cv-grid { grid-template-columns: 1fr; }
        .cv-sidebar { position: static; }
        .info-grid { grid-template-columns: 1fr; }
    }
</style>

