{% extends 'base.html.twig' %}

{% block title %}Portfolio — Aymen Boumliki{% endblock %}

{% block body %}

<style>
    /* ══════════════════════════════════
       BIO
    ══════════════════════════════════ */
    .bio-section {
        margin: 48px auto 0;
        max-width: 760px;
        padding: 0 24px;
    }

    .bio-block {
        background: rgba(0, 229, 255, 0.03);
        border: 1px dashed rgba(0, 229, 255, 0.2);
        padding: 22px 28px;
        font-size: 0.95rem;
        line-height: 1.8;
    }

    .bio-block .cmd {
        color: var(--accent-2);
        display: block;
        margin-bottom: 12px;
        font-size: 0.85rem;
        letter-spacing: 0.08em;
    }

    .bio-block p {
        color: var(--text);
        margin: 0;
    }

    /* ══════════════════════════════════
       SECTION HEADER
    ══════════════════════════════════ */
    .section-header {
        text-align: center;
        margin: 52px 0 28px;
    }

    .section-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.78rem;
        color: var(--accent-2);
        letter-spacing: 0.14em;
        margin-bottom: 10px;
    }

    .section-header h1 {
        font-family: 'Syne', sans-serif;
        font-size: 2.4rem;
        font-weight: 800;
        color: var(--text-bright);
        margin: 0 0 12px;
    }

    .section-header h1 span { color: var(--accent); }

    .section-header p {
        color: var(--text-dim);
        font-size: 0.95rem;
        max-width: 620px;
        margin: 0 auto;
        letter-spacing: 0.02em;
    }

    /* ══════════════════════════════════
       NAV
    ══════════════════════════════════ */
    .nav-competences {
        display: flex;
        justify-content: center;
        gap: 18px;
        flex-wrap: wrap;
        margin: 40px 0 28px;
    }

    .nav-btn {
        padding: 12px 22px;
        background: var(--accent);
        color: var(--bg);
        border: none;
        cursor: pointer;
        font-family: 'Space Mono', monospace;
        font-size: 0.9rem;
        transition: background 0.25s;
    }

    .nav-btn:hover,
    .nav-btn.active { background: var(--accent-2); }

    /* ══════════════════════════════════
       COMPETENCE PANEL
    ══════════════════════════════════ */
    .competence-section {
        display: none;
        margin: 0 auto 60px;
        max-width: 820px;
        padding: 0 24px;
    }

    .competence-section.active { display: block; }

    .competence-title {
        font-family: 'Syne', sans-serif;
        font-size: 2rem;
        font-weight: 800;
        color: var(--accent);
        margin: 0 0 24px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--border);
    }

    /* ══════════════════════════════════
       CARD
    ══════════════════════════════════ */
    .evidence-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        padding: 28px 32px;
        margin-bottom: 28px;
    }

    /* ══════════════════════════════════
       AUTO-EVAL HUD
    ══════════════════════════════════ */
    .autoeval-block {
        margin-bottom: 32px;
        padding: 20px 22px;
        background: rgba(0, 229, 255, 0.04);
        border: 1px solid rgba(0, 229, 255, 0.2);
        position: relative;
        overflow: hidden;
    }

    .autoeval-block::before {
        content: '';
        position: absolute;
        top: 0; left: 0;
        width: 4px; height: 100%;
        background: linear-gradient(180deg, var(--accent), var(--accent-2));
    }

    .autoeval-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        margin-bottom: 14px;
    }

    .autoeval-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.72rem;
        color: var(--accent-2);
        letter-spacing: 0.12em;
        text-transform: uppercase;
    }

    .autoeval-score {
        font-family: 'Syne', sans-serif;
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--accent);
        line-height: 1;
    }

    .autoeval-score small {
        font-size: 0.8rem;
        color: var(--text-dim);
        font-weight: 400;
    }

    .autoeval-segments {
        display: flex;
        gap: 6px;
        margin-bottom: 10px;
    }

    .seg {
        flex: 1;
        height: 10px;
        background: rgba(0, 229, 255, 0.1);
        border: 1px solid rgba(0, 229, 255, 0.2);
        position: relative;
        overflow: hidden;
    }

    .seg.on {
        background: linear-gradient(90deg, var(--accent-2), var(--accent));
        border-color: var(--accent);
        box-shadow: 0 0 8px rgba(0, 229, 255, 0.35);
    }

    .seg.on::after {
        content: '';
        position: absolute;
        top: 0; left: -60%;
        width: 40%; height: 100%;
        background: rgba(255,255,255,0.22);
        transform: skewX(-20deg);
        animation: shimmer 2.2s infinite;
    }

    @keyframes shimmer {
        0%   { left: -60%; }
        100% { left: 140%; }
    }

    .autoeval-ticks {
        display: flex;
        gap: 6px;
    }

    .tick {
        flex: 1;
        text-align: center;
        font-family: 'Space Mono', monospace;
        font-size: 0.65rem;
        color: var(--text-dim);
        letter-spacing: 0.06em;
    }

    .tick.on { color: var(--accent); }

    /* ══════════════════════════════════
       BLOCK TITLES
    ══════════════════════════════════ */
    .block-title {
        font-family: 'Space Mono', monospace;
        font-size: 0.76rem;
        color: var(--accent-2);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin: 28px 0 12px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .block-title::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, rgba(0,229,255,0.2), transparent);
    }

    /* ══════════════════════════════════
       TEXTE
    ══════════════════════════════════ */
    .reflexive-text {
        font-size: 0.94rem;
        line-height: 1.85;
        color: var(--text);
        margin: 0 0 12px;
    }

    /* ══════════════════════════════════
       AC TAGS
    ══════════════════════════════════ */
    .ac-list {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .ac-tag {
        font-family: 'Space Mono', monospace;
        font-size: 0.73rem;
        padding: 5px 11px;
        background: rgba(0, 229, 255, 0.06);
        border: 1px solid rgba(0, 229, 255, 0.22);
        color: var(--accent);
        letter-spacing: 0.04em;
        transition: background 0.2s;
    }

    .ac-tag:hover { background: rgba(0, 229, 255, 0.14); }

    /* ══════════════════════════════════
       INFO GRID
    ══════════════════════════════════ */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 14px;
    }

    @media (max-width: 600px) {
        .info-grid { grid-template-columns: 1fr; }
    }

    .info-cell {
        background: rgba(0, 229, 255, 0.03);
        border: 1px dashed rgba(0, 229, 255, 0.15);
        padding: 14px 16px;
    }

    .info-cell strong {
        display: block;
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        color: var(--accent-2);
        letter-spacing: 0.1em;
        margin-bottom: 6px;
        text-transform: uppercase;
    }

    .info-cell p {
        margin: 0;
        font-size: 0.87rem;
        line-height: 1.65;
        color: var(--text);
    }

    /* ══════════════════════════════════
       GALERIE
    ══════════════════════════════════ */
    .gallery-header {
        font-family: 'Space Mono', monospace;
        font-size: 0.76rem;
        color: var(--accent-2);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        margin: 32px 0 14px;
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .gallery-header::after {
        content: '';
        flex: 1;
        height: 1px;
        background: linear-gradient(90deg, rgba(0,229,255,0.2), transparent);
    }

    .evidence-gallery {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
        gap: 14px;
    }

    .evidence-item {
        background: rgba(0, 229, 255, 0.04);
        border: 1px solid var(--border);
        overflow: hidden;
        cursor: pointer;
        position: relative;
        transition: border-color 0.25s, transform 0.25s;
    }

    .evidence-item:hover {
        border-color: var(--accent);
        transform: translateY(-3px);
    }

    .evidence-item::after {
        content: '⤢  agrandir';
        font-family: 'Space Mono', monospace;
        font-size: 0.72rem;
        letter-spacing: 0.06em;
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(0,0,0,0.55);
        color: var(--accent);
        opacity: 0;
        transition: opacity 0.2s;
    }

    .evidence-item:hover::after { opacity: 1; }

    .evidence-item img {
        width: 100%;
        height: 210px;
        object-fit: cover;
        display: block;
    }

    .evidence-caption {
        padding: 8px 12px;
        font-family: 'Space Mono', monospace;
        font-size: 0.7rem;
        color: var(--text-dim);
        letter-spacing: 0.05em;
        background: var(--bg-card);
    }

    /* ══════════════════════════════════
       LIGHTBOX
    ══════════════════════════════════ */
    .lightbox {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(0,0,0,0.92);
        align-items: center;
        justify-content: center;
        flex-direction: column;
        gap: 18px;
        backdrop-filter: blur(4px);
    }

    .lightbox.open { display: flex; }

    .lightbox img {
        max-width: 88vw;
        max-height: 80vh;
        object-fit: contain;
        border: 1px solid var(--accent);
        box-shadow: 0 0 60px rgba(0,229,255,0.18);
        animation: lb-in 0.2s ease;
    }

    @keyframes lb-in {
        from { opacity: 0; transform: scale(0.96); }
        to   { opacity: 1; transform: scale(1); }
    }

    .lightbox-bar {
        display: flex;
        align-items: center;
        gap: 16px;
    }

    .lightbox-caption {
        font-family: 'Space Mono', monospace;
        font-size: 0.78rem;
        color: var(--text-dim);
        letter-spacing: 0.06em;
        min-width: 160px;
        text-align: center;
    }

    .lb-btn {
        font-family: 'Space Mono', monospace;
        font-size: 0.82rem;
        background: none;
        border: 1px solid var(--border);
        padding: 7px 16px;
        cursor: pointer;
        transition: border-color 0.2s, color 0.2s;
        letter-spacing: 0.06em;
    }

    .lb-btn:hover { border-color: var(--accent); color: var(--accent); }

    .lb-btn.close {
        border-color: var(--accent);
        color: var(--accent);
    }

    .lb-btn.close:hover {
        background: var(--accent);
        color: var(--bg);
    }
</style>

<!-- BIO -->
<div class="bio-section">
    <div class="bio-block">
        <span class="cmd">$ cat ce_qui_me_construit.txt</span>
        <p>
            Ce qui me construit : patience, rigueur et curiosité. Je suis motivé par
            l'administration des réseaux, la connexion des systèmes et la programmation
            de solutions qui facilitent le travail de tous.
        </p>
    </div>
</div>

<!-- HEADER -->
<div class="section-header">
    <div class="section-label">// compétences</div>
    <h1>Mon <span>portfolio</span></h1>
    <p>Présentation de mes compétences RT1, RT2 et RT3 avec analyses, preuves et visuels.</p>
</div>

<!-- NAV -->
<div class="nav-competences">
    <button class="nav-btn active" onclick="showCompetence('rt1', this)">RT1 - Administrer les réseaux et l'Internet</button>
    <button class="nav-btn" onclick="showCompetence('rt2', this)">RT2 - Connecter les entreprises et les usagers</button>
    <button class="nav-btn" onclick="showCompetence('rt3', this)">RT3 - Programmer</button>
</div>

<!-- ════ RT1 ════ -->
<div id="rt1" class="competence-section active">
    <h2 class="competence-title">RT1 - Administrer</h2>

    <div class="evidence-card">
        <div class="autoeval-block">
            <div class="autoeval-header">
                <span class="autoeval-label">// auto-évaluation</span>
                <span class="autoeval-score">4 <small>/ 4</small></span>
            </div>
            <div class="autoeval-segments">
                <div class="seg on"></div>
                <div class="seg on"></div>
                <div class="seg on"></div>
                <div class="seg on"></div>
            </div>
            <div class="autoeval-ticks">
                <div class="tick on">01</div>
                <div class="tick on">02</div>
                <div class="tick on">03</div>
                <div class="tick on">04</div>
            </div>
        </div>

        <div class="block-title">// analyse réflexive</div>
        <p class="reflexive-text">
            Lors du projet SAE 1.02, j'ai dû réaliser l'audit d'un switch (S2) dont les paramètres étaient inconnus.
            J'ai utilisé Wireshark pour capturer les messages CDP et identifier l'IP d'administration, puis j'ai configuré
            une nouvelle architecture réseau en intégrant des mesures de sécurité comme le Port-Security sur les accès sensibles.
        </p>
        <p class="reflexive-text">
            Au début, j'ai ressenti une certaine appréhension face à l'inconnu, notamment lors de l'analyse de la trame 36.
            La réussite de l'identification des ressources critiques m'a donné confiance. J'ai éprouvé de la frustration lors
            d'une panne physique (LED orange sur un port), mais le sentiment de satisfaction a été réel une fois le diagnostic posé.
        </p>
        <p class="reflexive-text">
            La configuration logicielle sur Packet Tracer était parfaite, ce qui a facilité le passage au matériel réel.
            Ce projet m'a permis de valider ma capacité à assister un administrateur réseau — une méthodologie rigoureuse
            (audit → simulation → réalisation) est indispensable. Pour mes prochains projets, je compte accorder plus
            d'importance aux tests de continuité de câblage dès le début de l'installation.
        </p>

        <div class="block-title">// apprentissages critiques</div>
        <ul class="ac-list">
            <li class="ac-tag">AC0111 — Électricité fondamentale</li>
            <li class="ac-tag">AC0112 — Systèmes numériques</li>
            <li class="ac-tag">AC0113 — Configuration réseau local</li>
            <li class="ac-tag">AC0114 — Systèmes d'exploitation</li>
            <li class="ac-tag">AC0115 — Dysfonctionnements réseau</li>
            <li class="ac-tag">AC0116 — Installation poste client</li>
        </ul>

        <div class="block-title">// contexte & savoirs</div>
        <div class="info-grid">
            <div class="info-cell">
                <strong>Contexte</strong>
                <p>Audit et extension sécurisée d'une infrastructure réseau dans le cadre de la croissance d'une entreprise.</p>
            </div>
            <div class="info-cell">
                <strong>Savoirs</strong>
                <p>CDP · ICMP · ARP · VLANs & Trunking 802.1Q · Port-Security · SSH · SPAN/Port Mirroring</p>
            </div>
            <div class="info-cell">
                <strong>Savoir-faire</strong>
                <p>Analyse Wireshark · Config Cisco · TFTP & DHCP · Dépannage câblage physique</p>
            </div>
            <div class="info-cell">
                <strong>Résultats</strong>
                <p>4 VLANs déployés, pings validés, trafic monitoré via SPAN, accès admin sécurisé.</p>
            </div>
        </div>
    </div>

    <div class="gallery-header">// preuves photographiques</div>
    <div class="evidence-gallery" id="gallery-rt1">
        {% set rt1imgs = ['C1RT1.JPG','C2RT1.JPG','C3RT1.JPG','C4RT1.JPG','C5RT1.JPG'] %}
        {% for i, f in rt1imgs %}
        {% set src = asset(f) %}
        <div class="evidence-item" data-gallery="gallery-rt1" data-index="{{ i }}" onclick="openLightbox(this)">
            <img src="{{ src }}" alt="Page {{ i+1 }} RT1" data-src="{{ src }}" data-caption="RT1 — Page {{ i+1 }}">
            <div class="evidence-caption">Page {{ i+1 }}</div>
        </div>
        {% endfor %}
    </div>
</div>

<!-- ════ RT2 ════ -->
<div id="rt2" class="competence-section">
    <h2 class="competence-title">RT2 - Connecter</h2>

    <div class="evidence-card">
        <div class="autoeval-block">
            <div class="autoeval-header">
                <span class="autoeval-label">// auto-évaluation</span>
                <span class="autoeval-score">4 <small>/ 4</small></span>
            </div>
            <div class="autoeval-segments">
                <div class="seg on"></div>
                <div class="seg on"></div>
                <div class="seg on"></div>
                <div class="seg on"></div>
            </div>
            <div class="autoeval-ticks">
                <div class="tick on">01</div>
                <div class="tick on">02</div>
                <div class="tick on">03</div>
                <div class="tick on">04</div>
            </div>
        </div>

        <div class="block-title">// analyse réflexive</div>
        <p class="reflexive-text">
            J'ai monté un circuit RC pour analyser sa réponse fréquentielle de 20 Hz à 100 kHz. La visualisation concrète
            de la déformation du signal carré sur l'oscilloscope m'a aidé à mieux ancrer la théorie. Le montage et les mesures
            à basse fréquence ont bien fonctionné ; la précision était plus difficile à haute fréquence à cause du bruit.
        </p>
        <p class="reflexive-text">
            J'ai mobilisé mes connaissances sur les impédances complexes pour valider mes mesures par le calcul.
            L'utilisation de Python pour le diagramme de Bode a permis une visualisation plus précise que le tracé manuel.
            Ce TP m'a permis de comprendre que le filtre lisse le signal en éliminant les variations brusques (hautes fréquences).
            J'aurais dû être plus attentif au réglage de l'échelle de l'oscilloscope.
        </p>

        <div class="block-title">// apprentissages critiques</div>
        <ul class="ac-list">
            <li class="ac-tag">AC12.01 — Mesurer, analyser, commenter les signaux</li>
            <li class="ac-tag">AC12.02 — Caractériser les transmissions élémentaires</li>
        </ul>

        <div class="block-title">// contexte & savoirs</div>
        <div class="info-grid">
            <div class="info-cell">
                <strong>Contexte</strong>
                <p>TP 1 — Ressource R2.05 (Mesures et Tests) : étude fréquentielle d'un filtre passe-bas RC.</p>
            </div>
            <div class="info-cell">
                <strong>Savoirs</strong>
                <p>Lois de l'électricité · Condensateur en régime fréquentiel · Fréquence de coupure</p>
            </div>
            <div class="info-cell">
                <strong>Savoir-faire</strong>
                <p>Oscilloscope Tektronix TDS 2012B · Générateur de fonctions · Excel & Python (Bode)</p>
            </div>
            <div class="info-cell">
                <strong>Savoir-être</strong>
                <p>Rigueur dans les mesures · Respect des consignes de sécurité électrique</p>
            </div>
        </div>
    </div>

    <div class="gallery-header">// preuves photographiques</div>
    <div class="evidence-gallery" id="gallery-rt2">
        {% set rt2imgs = ['C1RT2.JPG','C2RT2.JPG','C3RT2.JPG','C4RT2.JPG','C5RT2.JPG','C6RT2.JPG'] %}
        {% for i, f in rt2imgs %}
        {% set src = asset(f) %}
        <div class="evidence-item" data-gallery="gallery-rt2" data-index="{{ i }}" onclick="openLightbox(this)">
            <img src="{{ src }}" alt="Page {{ i+1 }} RT2" data-src="{{ src }}" data-caption="RT2 — Page {{ i+1 }}">
            <div class="evidence-caption">Page {{ i+1 }}</div>
        </div>
        {% endfor %}
    </div>
</div>

<!-- ════ RT3 ════ -->
<div id="rt3" class="competence-section">
    <h2 class="competence-title">RT3 - Créer des outils et des applications informatiques pour les R&T</h2>

    <div class="evidence-card">
        <div class="autoeval-block">
            <div class="autoeval-header">
                <span class="autoeval-label">// auto-évaluation</span>
                <span class="autoeval-score">3 <small>/ 4</small></span>
            </div>
            <div class="autoeval-segments">
                <div class="seg on"></div>
                <div class="seg on"></div>
                <div class="seg on"></div>
                <div class="seg"></div>
            </div>
            <div class="autoeval-ticks">
                <div class="tick on">01</div>
                <div class="tick on">02</div>
                <div class="tick on">03</div>
                <div class="tick">04</div>
            </div>
        </div>

        <div class="block-title">// analyse réflexive</div>
        <p class="reflexive-text">
            Le projet SAE 1.05 a marqué une étape clé dans mon apprentissage de RT3. Ma principale difficulté résidait dans
            la conversion de flux textuels bruts (tcpdump) en données structurées exploitables (CSV).
        </p>
        <p class="reflexive-text">
            J'ai résolu ce problème en concevant un script Python d'extraction de données, couplé à une interface web interactive
            (HTML/JS) pour la visualisation immédiate des alertes, ainsi qu'un export structuré vers Excel pour des analyses
            forensiques approfondies. Pour répondre aux besoins des collaborateurs basés en Inde, j'ai rédigé une documentation
            technique en anglais, assurant la continuité opérationnelle entre les équipes internationales.
        </p>
        <p class="reflexive-text">
            Cette approche hybride m'a permis de comprendre qu'un diagnostic réseau efficace repose sur la complémentarité entre
            l'automatisation logicielle et la précision de l'analyse tabulaire. Pour l'avenir, j'envisage d'automatiser davantage
            la détection de signatures d'attaques en temps réel.
        </p>

        <div class="block-title">// apprentissages critiques</div>
        <ul class="ac-list">
            <li class="ac-tag">AC0311 — Système informatique & outils</li>
            <li class="ac-tag">AC0312 — Lire, exécuter, corriger un programme</li>
            <li class="ac-tag">AC0313 — Traduire un algorithme</li>
            <li class="ac-tag">AC0314 — Architecture Web</li>
            <li class="ac-tag">AC0315 — Gestion de données</li>
            <li class="ac-tag">AC0316 — Travail collaboratif</li>
        </ul>

        <div class="block-title">// contexte & savoirs</div>
        <div class="info-grid">
            <div class="info-cell">
                <strong>Contexte</strong>
                <p>SAE 1.05 — Outil d'analyse forensique réseau avec collaboration internationale (Inde).</p>
            </div>
            <div class="info-cell">
                <strong>Savoir-faire</strong>
                <p>Scripting Python · Interface HTML/JS · Analyse Excel · Documentation en anglais</p>
            </div>
            <div class="info-cell">
                <strong>Savoir-être</strong>
                <p>Collaboration internationale · Rigueur · Autonomie</p>
            </div>
            <div class="info-cell">
                <strong>Résultats</strong>
                <p>Outil fonctionnel tcpdump → CSV → visualisation web + export Excel + documentation technique.</p>
            </div>
        </div>
    </div>

    <div class="gallery-header">// preuves photographiques</div>
    <div class="evidence-gallery" id="gallery-rt3">
        {% set rt3imgs = ['C1RT3.JPG','C2RT3.JPG','C4RT3.jpg','C5RT3.jpg','C6RT3.jpg','C7RT3.jpg'] %}
        {% for i, f in rt3imgs %}
        {% set src = asset(f) %}
        <div class="evidence-item" data-gallery="gallery-rt3" data-index="{{ i }}" onclick="openLightbox(this)">
            <img src="{{ src }}" alt="Page {{ i+1 }} RT3" data-src="{{ src }}" data-caption="RT3 — Page {{ i+1 }}">
            <div class="evidence-caption">Page {{ i+1 }}</div>
        </div>
        {% endfor %}
    </div>
</div>

<!-- LIGHTBOX -->
<div class="lightbox" id="lightbox" onclick="lbClickOut(event)">
    <img id="lb-img" src="" alt="">
    <div class="lightbox-bar">
        <button class="lb-btn" onclick="lbNav(-1)">← préc</button>
        <span class="lightbox-caption" id="lb-caption"></span>
        <button class="lb-btn" onclick="lbNav(1)">suiv →</button>
        <button class="lb-btn close" onclick="closeLb()">✕ fermer</button>
    </div>
</div>

<script>
    function showCompetence(id, btn) {
        document.querySelectorAll('.competence-section').forEach(s => s.classList.remove('active'));
        document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
        document.getElementById(id).classList.add('active');
        btn.classList.add('active');
    }

    let lbImages = [], lbIndex = 0;

    function openLightbox(el) {
        const galleryId = el.dataset.gallery;
        const idx       = parseInt(el.dataset.index);
        lbImages = Array.from(
            document.getElementById(galleryId).querySelectorAll('img')
        ).map(img => ({ src: img.dataset.src, caption: img.dataset.caption }));
        lbIndex = idx;
        renderLb();
        document.getElementById('lightbox').classList.add('open');
        document.body.style.overflow = 'hidden';
    }

    function renderLb() {
        const lb = document.getElementById('lb-img');
        lb.style.animation = 'none';
        lb.offsetHeight; // reflow
        lb.style.animation = '';
        lb.src = lbImages[lbIndex].src;
        document.getElementById('lb-caption').textContent =
            lbImages[lbIndex].caption + '  (' + (lbIndex + 1) + ' / ' + lbImages.length + ')';
    }

    function lbNav(dir) {
        lbIndex = (lbIndex + dir + lbImages.length) % lbImages.length;
        renderLb();
    }

    function closeLb() {
        document.getElementById('lightbox').classList.remove('open');
        document.body.style.overflow = '';
    }

    function lbClickOut(e) {
        if (e.target === document.getElementById('lightbox')) closeLb();
    }

    document.addEventListener('keydown', e => {
        if (!document.getElementById('lightbox').classList.contains('open')) return;
        if (e.key === 'Escape')     closeLb();
        if (e.key === 'ArrowLeft')  lbNav(-1);
        if (e.key === 'ArrowRight') lbNav(1);
    });
</script>

{% endblock %}
