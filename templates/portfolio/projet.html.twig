{% extends 'base.html.twig' %}

{% block title %}Projets & Loisirs — Aymen Boumliki{% endblock %}

{% block body %}

<style>
    /* ── En-tête de section ── */
    .section-header {
        text-align: center;
        margin-bottom: 48px;
        padding-top: 48px;
    }

    .section-header h1,
    .section-header h2 {
        font-family: 'Syne', sans-serif;
        font-size: 2.4rem;
        font-weight: 800;
        color: var(--text-bright);
        margin-bottom: 12px;
    }

    .section-header h1 span,
    .section-header h2 span {
        color: var(--accent);
    }

    .section-header h2 span.violet {
        color: var(--accent-2);
    }

    .section-header p {
        color: var(--text-dim);
        font-size: 0.9rem;
        max-width: 560px;
        margin: 0 auto;
        letter-spacing: 0.02em;
    }

    /* ── Grille projets ── */
    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
        gap: 24px;
        margin-bottom: 80px;
    }

    /* ── Card projet ── */
    .project-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        padding: 28px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: border-color 0.3s, box-shadow 0.3s, transform 0.3s;
        position: relative;
        overflow: hidden;
    }

    .project-card::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--accent), var(--accent-2));
        opacity: 0;
        transition: opacity 0.3s;
    }

    .project-card:hover {
        border-color: var(--border-hover);
        box-shadow: 0 0 28px var(--accent-glow);
        transform: translateY(-3px);
    }

    .project-card:hover::before {
        opacity: 1;
    }

    /* ── Icône card ── */
    .card-icon {
        width: 52px;
        height: 52px;
        border: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        font-size: 1.5rem;
        color: var(--accent);
        background: rgba(0,229,255,0.06);
    }

    .card-icon.violet {
        color: var(--accent-2);
        background: rgba(168,85,247,0.07);
        border-color: rgba(168,85,247,0.25);
    }

    /* ── Titre carte ── */
    .project-card h3 {
        font-family: 'Syne', sans-serif;
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--text-bright);
        margin-bottom: 12px;
    }

    .project-card p {
        color: var(--text-dim);
        font-size: 0.85rem;
        line-height: 1.7;
    }

    /* ── Scores ANSSI ── */
    .score-grid {
        background: rgba(0,229,255,0.04);
        border: 1px solid var(--border);
        padding: 14px 16px;
        margin: 16px 0;
        font-size: 0.78rem;
    }

    .score-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 5px 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
    }

    .score-row:last-child { border-bottom: none; }

    .score-row span { color: var(--text-dim); }

    .score-row strong { color: var(--accent); font-size: 0.82rem; }

    /* ── Footer card ── */
    .card-footer {
        margin-top: 20px;
        padding-top: 14px;
        border-top: 1px solid var(--border);
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .card-footer .cat {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.12em;
        color: var(--accent);
    }

    .badge {
        font-size: 0.65rem;
        padding: 2px 10px;
        border: 1px solid var(--accent);
        color: var(--accent);
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .badge.green {
        border-color: #22c55e;
        color: #22c55e;
    }

    /* ── Bouton téléchargement ── */
    .btn-dl {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        padding: 11px 16px;
        font-family: 'Space Mono', monospace;
        font-size: 0.78rem;
        text-decoration: none;
        color: var(--accent);
        border: 1px solid var(--accent);
        background: transparent;
        letter-spacing: 0.04em;
        transition: background 0.2s, color 0.2s, box-shadow 0.2s;
        margin-top: 4px;
    }

    .btn-dl:hover {
        background: var(--accent);
        color: var(--bg);
        box-shadow: 0 0 18px var(--accent-glow);
    }

    /* ── Loisirs ── */
    .hobbies-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 20px;
    }

    /* ── CTA bas de page ── */
    .cta-block {
        text-align: center;
        margin-top: 72px;
        padding: 40px;
        border: 1px solid var(--border);
        background: var(--bg-card);
        position: relative;
        overflow: hidden;
    }

    .cta-block::after {
        content: '';
        position: absolute;
        bottom: 0; left: 50%; transform: translateX(-50%);
        width: 60%;
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--accent), transparent);
    }

    .cta-block p {
        color: var(--text-dim);
        font-size: 0.85rem;
        margin-bottom: 20px;
    }
</style>

{# ────────────────────────────────────────────
   SECTION 1 — PROJETS TECHNIQUES
──────────────────────────────────────────── #}
<div class="section-header">
    <div class="section-label">// projets</div>
    <h1>Réalisations <span>Techniques</span></h1>
    <p>Réalisations académiques et certifications officielles en Réseaux & Cybersécurité.</p>
</div>

<div class="projects-grid">

    {# SAE 1.02 #}
    <div class="project-card">
        <div>
            <div class="card-icon">
                <i class="fas fa-network-wired"></i>
            </div>
            <h3>SAE 1.02 — Initiation Réseaux</h3>
            <p>Conception de réseaux locaux : adressage IP, configuration de switchs Cisco et analyse de connectivité.</p>
        </div>
        <div class="card-footer">
            <span class="cat">Infrastructure & Commutation</span>
            <span class="badge">SAE</span>
        </div>
    </div>

    {# SecNumacadémie #}
    <div class="project-card">
        <div>
            <div class="card-icon">
                <i class="fas fa-shield-halved"></i>
            </div>
            <h3>Certification SecNumacadémie</h3>
            <p>Formation délivrée par l'<strong style="color:var(--text-bright)">ANSSI</strong> — validée avec succès le 25/09/2025.</p>

            <div class="score-grid">
                <div class="score-row">
                    <span>Panorama de la SSI</span>
                    <strong>82 %</strong>
                </div>
                <div class="score-row">
                    <span>Authentification</span>
                    <strong>82 %</strong>
                </div>
                <div class="score-row">
                    <span>Sécurité sur Internet</span>
                    <strong>88 %</strong>
                </div>
                <div class="score-row">
                    <span>Poste de travail & Nomadisme</span>
                    <strong>80 %</strong>
                </div>
            </div>

            <a href="{{ asset('ATTESTATION SECNUM.pdf') }}" target="_blank" class="btn-dl">
                <i class="fas fa-file-pdf"></i> Voir l'attestation officielle
            </a>
        </div>
        <div class="card-footer">
            <span class="cat">Cybersécurité</span>
            <span class="badge green">Certifié</span>
        </div>
    </div>

</div>

<div class="divider"></div>

{# ────────────────────────────────────────────
   SECTION 2 — LOISIRS
──────────────────────────────────────────── #}
<div class="section-header" style="padding-top: 20px;">
    <div class="section-label">// loisirs</div>
    <h2>Ce qui me <span class="violet">construit</span></h2>
    <p>Discipline, créativité et transmission — hors écran.</p>
</div>

<div class="hobbies-grid">

    {# Judo #}
    <div class="project-card">
        <div class="card-icon violet">
            <i class="fas fa-medal"></i>
        </div>
        <h3>Judo — Compétition</h3>
        <p><strong style="color:var(--accent-2)">4× champion</strong>. Discipline, respect et persévérance acquis sur les tatamis depuis des années.</p>
        <div class="card-footer">
            <span class="cat" style="color: var(--accent-2);">Sport de combat</span>
        </div>
    </div>

    {# Coaching #}
    <div class="project-card">
        <div class="card-icon violet">
            <i class="fas fa-users"></i>
        </div>
        <h3>Coaching</h3>
        <p>Transmission pédagogique auprès de jeunes débutants. Développement du leadership et de l'écoute active.</p>
        <div class="card-footer">
            <span class="cat" style="color: var(--accent-2);">Pédagogie</span>
        </div>
    </div>

    {# Design #}
    <div class="project-card">
        <div class="card-icon violet">
            <i class="fas fa-laptop-code"></i>
        </div>
        <h3>Création Digitale</h3>
        <p>Réalisation graphique sous Photoshop. Identités visuelles et logos pour projets personnels.</p>
        <div class="card-footer">
            <span class="cat" style="color: var(--accent-2);">Design & Visuel</span>
        </div>
    </div>

</div>

{# ── CTA ── #}
<div class="cta-block">
    <div class="section-label">// next</div>
    <p>Voir l'ensemble de mon parcours académique et professionnel.</p>
    <a href="{{ path('app_cv') }}" class="btn">
        Consulter mon CV <i class="fas fa-arrow-right" style="margin-left: 8px;"></i>
    </a>
</div>

{% endblock %}
